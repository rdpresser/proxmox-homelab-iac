# =====================================================
# Observability Stack — Optional Environment Overrides
# =====================================================
# Copy to .env to override defaults. No .env needed to run.
#
# Usage:
#   cp .env.example .env
#   # edit .env as needed
#   docker compose up -d
# =====================================================

# Grafana credentials (defaults: admin / admin)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Port bindings (defaults shown)
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# Prometheus retention (default: 15d)
PROMETHEUS_RETENTION=15d
